# MARTA train API key — request at https://itsmarta.com/app-developer-resources.aspx
MARTA_TRAIN_KEY=

# Bluesky
BLUESKY_SERVICE=https://bsky.social
BLUESKY_BUS_IDENTIFIER=
BLUESKY_BUS_APP_PASSWORD=
BLUESKY_TRAIN_IDENTIFIER=
BLUESKY_TRAIN_APP_PASSWORD=
# Alerts/disruptions account — used by bin/{bus,train}/alerts.js and bin/train/pulse.js
BLUESKY_ALERTS_IDENTIFIER=
BLUESKY_ALERTS_APP_PASSWORD=

# Throwaway Bluesky account for manually testing post output without publishing
# to a live bot account. Optional — no automated job reads these.
TEST_ACCOUNT_IDENTIFIER=
TEST_ACCOUNT_PASSWORD=

# Mapbox — https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=

# GitHub PAT used by bin/push-web-data.sh to fire a repository_dispatch that
# rebuilds the public site after data is uploaded to R2. Fine-grained token with
# Contents:write on cailinpitt/chicago-transit-alerts. Keep the value unquoted —
# the script greps it out of this file with `cut -d= -f2-`. Optional: if unset,
# the upload still happens and the site's 30-min scheduled build is the catch-up.
GITHUB_DISPATCH_TOKEN=
