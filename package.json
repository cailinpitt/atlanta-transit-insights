{
  "name": "atlanta-transit-insights",
  "version": "0.0.1",
  "description": "Bluesky bots that turn MARTA train and bus tracker data into Atlanta-specific transit visualizations",
  "dependencies": {
    "@atproto/api": "^0.18.16",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^8.1.0",
    "gtfs-realtime-bindings": "^2.0.0",
    "minimist": "^1.2.3",
    "sharp": "^0.34.5"
  },
  "scripts": {
    "marta:fetch-gtfs": "node scripts/marta/fetch-static-gtfs.js",
    "marta:build-schedule-index": "node scripts/marta/build-schedule-index.js",
    "marta:build-schedule-stops": "node scripts/marta/build-schedule-stops.js",
    "marta:build-rail-stations": "node scripts/marta/build-rail-stations.js",
    "marta:backfill-alert-stations": "node scripts/marta/backfill-alert-stations.js",
    "marta:observe-buses": "node scripts/marta/observe-buses.js",
    "marta:observe-bus-tripupdates": "node scripts/marta/observe-bus-tripupdates.js",
    "marta:observe-rail": "node scripts/marta/observe-rail.js",
    "marta:status": "node scripts/marta/observe-status.js",
    "marta:bus-gaps": "node bin/marta/bus/gaps.js",
    "marta:bus-gaps:dry": "node bin/marta/bus/gaps.js --dry-run",
    "marta:bus-ghosts": "node bin/marta/bus/ghosts.js",
    "marta:bus-ghosts:dry": "node bin/marta/bus/ghosts.js --dry-run",
    "marta:bus-cancellation-surge": "node bin/marta/bus/cancellation-surge.js",
    "marta:bus-cancellation-surge:dry": "node bin/marta/bus/cancellation-surge.js --dry-run",
    "marta:bus-speedmap": "node bin/marta/bus/speedmap.js",
    "marta:bus-speedmap:dry": "node bin/marta/bus/speedmap.js --dry-run",
    "marta:bus-crowding-map": "node bin/marta/bus/crowding-map.js",
    "marta:bus-crowding-map:dry": "node bin/marta/bus/crowding-map.js --dry-run",
    "marta:bus-crowding-rollup": "node bin/marta/bus/crowding-rollup.js",
    "marta:bus-crowding-rollup:dry": "node bin/marta/bus/crowding-rollup.js --dry-run",
    "marta:rail-gaps": "node bin/marta/rail/gaps.js",
    "marta:rail-gaps:dry": "node bin/marta/rail/gaps.js --dry-run",
    "marta:rail-bunching": "node bin/marta/rail/bunching.js",
    "marta:rail-bunching:dry": "node bin/marta/rail/bunching.js --dry-run",
    "marta:rail-ghosts": "node bin/marta/rail/ghosts.js",
    "marta:rail-ghosts:dry": "node bin/marta/rail/ghosts.js --dry-run",
    "marta:rail-speedmap": "node bin/marta/rail/speedmap.js",
    "marta:rail-speedmap:dry": "node bin/marta/rail/speedmap.js --dry-run",
    "marta:rail-adherence": "node bin/marta/rail/adherence.js",
    "marta:rail-adherence:dry": "node bin/marta/rail/adherence.js --dry-run",
    "marta:export-web": "node bin/marta/export-web.js",
    "marta:gen-avatars": "node scripts/marta/generate-avatar.js",
    "marta:set-profile": "node scripts/marta/set-profile.js",
    "marta:cross-follow": "node scripts/marta/cross-follow.js",
    "marta:create-starter-pack": "node scripts/marta/create-starter-pack.js",
    "marta:post-intro": "node scripts/marta/post-intro.js",
    "test": "node --test test/*.test.js test/**/*.test.js",
    "smoke": "for f in bin/marta/bus/*.js bin/marta/rail/*.js; do node \"$f\" --check || exit 1; done",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "knip": "knip --include files,dependencies",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,json}": "biome check --write --no-errors-on-unmatched"
  },
  "author": "Cailin Pitt <cailinpitt1@gmail.com> (https://cailinpitt.com)",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "lint-staged": "^16.4.0"
  }
}
